# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/litterdesk
POSTGRES_PASSWORD=changeme

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-generate-a-real-one

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # $29/mo price ID
STRIPE_PRICE_PRO=price_...       # $79/mo price ID
STRIPE_PRICE_KENNEL=price_...    # $149/mo price ID

# ─── Anthropic AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@litterdesk.com

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://litterdesk.com
ENVIRONMENT=production
ALLOWED_ORIGINS=["https://litterdesk.com","https://www.litterdesk.com"]

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://litterdesk.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
